# MongoDB
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/vectordb?retryWrites=true&w=majority

# Google Vertex AI
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
GENERATION_MODEL=gemini-2.5-flash-lite
ROUTER_MODEL=gemini-2.5-flash
EXTRACTION_MODEL=gemini-2.5-flash

# Use one of these credential options:
# Local development path:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# Hosted deployments such as Render:
VERTEX_CREDENTIALS={"type":"service_account","project_id":"..."}

# Voyage AI reranking
VOYAGE_API_KEY=your-voyage-api-key

# Auth
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_SECONDS=604800

# CORS: comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Optional evaluation
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
JUDGE_MODEL=vertex_ai:/gemini-2.5-flash-lite
